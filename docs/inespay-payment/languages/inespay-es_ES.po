msgid "Paste here the Production API Key provided by INESPAY"
msgstr "Copia aquí la API Key de Producción proporcionada por INESPAY"

#: inespay.php
msgid "API Token (Production)"
msgstr "API Token (Producción)"

#: inespay.php
msgid "Paste here the Production API Token provided by INESPAY"
msgstr "Copia aquí el API Token de Producción proporcionado por INESPAY"

#: inespay.php
msgid "To use this payment method in your production online store, you must use the Real Environment credentials."
msgstr "Para usar este método de pago en tu tienda de Producción, debes utilizar las credenciales reales proporcionadas por INESPAY."

#: inespay.php
msgid "Error: When using Real (Production) environment, you must provide both Production API Key and Production API Token."
msgstr "Error: Al usar el entorno Real (Producción), debes proporcionar tanto la API Key como el API Token de Producción."

#: inespay.php
msgid "Payment made at the bank, pending confirmation by Inespay."
msgstr "Pago realizado en el banco, pendiente de confirmación por Inespay."

#: inespay.php
msgid "The user has completed the payment at their bank. Reference: %s. Waiting for confirmation from the Inespay server."
msgstr "El usuario ha completado el pago en su banco. Referencia: %s. Esperando confirmación del servidor de Inespay."

#: inespay.php
msgid "Payment confirmed by the Inespay server."
msgstr "Pago confirmado por el servidor de Inespay."

#: inespay.php
msgid "Payment definitively confirmed by Inespay. Reference: %s"
msgstr "Pago confirmado definitivamente por Inespay. Referencia: %s"

#: inespay.php
msgid "Inespay notification received but the order is already in status: %s"
msgstr "Recibida notificación de Inespay pero el pedido ya está en estado: %s"

#: inespay.php
msgid "Payment cancelled by the user at the bank."
msgstr "Pago cancelado por el usuario en el banco."

#: inespay.php
msgid "User cancelled the payment at the bank. Reference: %s"
msgstr "Usuario canceló el pago en el banco. Referencia: %s"

#: inespay.php
msgid "ADVERTENCIA: Callback recibido sin tipo reconocido (tipo: \"%s\"). El pedido permanece en estado: %s. Referencia: %s. Verificar configuración de URLs."
msgstr "ADVERTENCIA: Callback recibido sin tipo reconocido (tipo: \"%s\"). El pedido permanece en estado: %s. Referencia: %s. Verificar configuración de URLs."

