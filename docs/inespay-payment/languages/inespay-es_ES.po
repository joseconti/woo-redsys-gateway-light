msgstr "Copia aquí la API Key de Test proporcionada por INESPAY"

#: inespay.php
msgid "API Token (Test/Sandbox)"
msgstr "API Token (Test/Sandbox)"

#: inespay.php
msgid "Paste here the Test API Token provided by INESPAY"
msgstr "Copia aquí el API Token de Test proporcionado por INESPAY"

#: inespay.php
msgid "Production Credentials"
msgstr "Credenciales de Producción"

#: inespay.php
msgid "These fields are REQUIRED when the selected environment is Real. You do not need to delete the Test credentials to use Production, or vice versa."
msgstr "Estos campos son OBLIGATORIOS cuando el entorno seleccionado es Real. No es necesario borrar las credenciales de Test para usar Producción, ni viceversa."

#: inespay.php
msgid "API Key (Production)"
msgstr "API Key (Producción)"

